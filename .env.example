# Kelta Local Development Environment Variables
# ─────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Generate dev keys: make gen-keys
#    (appends JWK_SET and KELTA_ENCRYPTION_KEY to .env)
# 3. Start the stack: make up
#
# Secrets below are DEV-ONLY. Never use these values in any deployed environment.

# ─────────────────────────────────────────────
# Authentication — kelta-auth
# ─────────────────────────────────────────────

# RSA JWK Set for JWT signing. Generated by `make gen-keys`.
# Format: single-line JSON {"keys":[{...RS256 private key...}]}
JWK_SET=

# AES-256 master key for envelope encryption (Base64-encoded 32 bytes).
# Generated by `make gen-keys` via: openssl rand -base64 32
KELTA_ENCRYPTION_KEY=

# Shared secret for internal service-to-service calls
KELTA_INTERNAL_TOKEN=dev-internal-token

# ─────────────────────────────────────────────
# AI service — kelta-ai (only needed with --profile ai)
# ─────────────────────────────────────────────

ANTHROPIC_API_KEY=

# Optional: override default Claude model
# AI_DEFAULT_MODEL=claude-sonnet-4-20250514

# ─────────────────────────────────────────────
# Logging overrides (optional)
# ─────────────────────────────────────────────

# LOG_LEVEL=INFO
# SECURITY_LOG_LEVEL=WARN
