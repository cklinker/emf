<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        OWASP Dependency-Check Suppressions
        ====================================
        Add false-positive suppressions here after reviewing the dependency-check report.
        Each suppression should include a comment explaining why it's a false positive.

        Example:
        <suppress>
            <notes><![CDATA[
                This is a false positive. The vulnerability applies to the server component,
                not the client library we use.
            ]]></notes>
            <packageUrl regex="true">^pkg:maven/com\.example/library@.*$</packageUrl>
            <cve>CVE-2024-XXXXX</cve>
        </suppress>
    -->
</suppressions>
