# Base URLs for the deployed environment
# BASE_URL = where the SPA is served (UI service with nginx)
# API_BASE_URL = where API calls go (gateway service)
E2E_BASE_URL=https://emf-ui.rzware.com
E2E_API_BASE_URL=https://emf.rzware.com

# Tenant
E2E_TENANT_SLUG=default

# kelta-auth direct login (preferred — avoids external IdP dependency)
E2E_AUTH_BASE_URL=https://emf-auth.rzware.com

# Authentik OIDC (legacy fallback)
E2E_AUTHENTIK_URL=https://authentik.rzware.com
E2E_OIDC_ISSUER=https://authentik.rzware.com/application/o/kelta/
E2E_CLIENT_ID=
E2E_OIDC_PROVIDER_ID=

# Test user credentials (browser-based login)
E2E_TEST_USERNAME=e2e-admin@kelta.local
E2E_TEST_PASSWORD=

# Service account for API-level test data operations (client_credentials grant)
E2E_SERVICE_CLIENT_ID=
E2E_SERVICE_CLIENT_SECRET=
