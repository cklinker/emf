# Server
SERVER_PORT=8080

# Upstream service URLs
KELTA_WORKER_URL=http://localhost:8081
KELTA_AUTH_URL=http://localhost:8082
KELTA_AI_URL=http://localhost:8083

# Redis (used for rate limiting and caching)
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# OAuth2 / OIDC
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://localhost:8082/realms/kelta

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Cerbos (authorization)
CERBOS_HOST=localhost
CERBOS_PORT=3593

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=kelta-gateway
