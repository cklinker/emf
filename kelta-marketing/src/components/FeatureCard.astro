---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
  <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-kelta-50 text-2xl">
    {icon}
  </div>
  <h3 class="mb-2 text-lg font-semibold text-navy">{title}</h3>
  <p class="text-sm leading-relaxed text-kelta-700">{description}</p>
</div>
