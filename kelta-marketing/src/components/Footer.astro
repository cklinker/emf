---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-100 bg-gray-50">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="grid gap-8 md:grid-cols-4">
      <div>
        <a href="/" class="flex items-center gap-2 text-lg font-bold text-kelta-700">
          <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-kelta-600 text-xs font-bold text-white">K</span>
          Kelta
        </a>
        <p class="mt-3 text-sm text-gray-500">
          The enterprise application platform. Open source, self-hosted, no vendor lock-in.
        </p>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-semibold text-gray-900">Product</h3>
        <ul class="space-y-2 text-sm text-gray-500">
          <li><a href="/features" class="hover:text-kelta-600">Features</a></li>
          <li><a href="/pricing" class="hover:text-kelta-600">Pricing</a></li>
          <li><a href="/docs" class="hover:text-kelta-600">Documentation</a></li>
        </ul>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-semibold text-gray-900">Developers</h3>
        <ul class="space-y-2 text-sm text-gray-500">
          <li><a href="https://github.com/cklinker/emf" target="_blank" rel="noopener noreferrer" class="hover:text-kelta-600">GitHub</a></li>
          <li><a href="/docs" class="hover:text-kelta-600">API Reference</a></li>
          <li><a href="/docs" class="hover:text-kelta-600">SDK</a></li>
        </ul>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-semibold text-gray-900">Company</h3>
        <ul class="space-y-2 text-sm text-gray-500">
          <li><a href="#" class="hover:text-kelta-600">About</a></li>
          <li><a href="#" class="hover:text-kelta-600">Blog</a></li>
          <li><a href="#" class="hover:text-kelta-600">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-10 border-t border-gray-200 pt-6 text-center text-sm text-gray-400">
      &copy; {currentYear} Kelta. All rights reserved.
    </div>
  </div>
</footer>
