---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-100 bg-kelta-50">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="grid gap-8 md:grid-cols-4">
      <div>
        <a href="/" class="flex items-center gap-2">
          <img src="/logo-primary.svg" alt="Kelta" class="h-7" />
        </a>
        <p class="mt-3 text-sm text-kelta-700">
          Built for platform engineers, by platform engineers. Open source, self-hosted, no vendor lock-in.
        </p>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-semibold text-navy">Product</h3>
        <ul class="space-y-2 text-sm text-kelta-700">
          <li><a href="/features" class="hover:text-cyan">Features</a></li>
          <li><a href="/pricing" class="hover:text-cyan">Pricing</a></li>
          <li><a href="/docs" class="hover:text-cyan">Documentation</a></li>
        </ul>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-semibold text-navy">Developers</h3>
        <ul class="space-y-2 text-sm text-kelta-700">
          <li><a href="https://github.com/cklinker/emf" target="_blank" rel="noopener noreferrer" class="hover:text-cyan">GitHub</a></li>
          <li><a href="/docs" class="hover:text-cyan">API Reference</a></li>
          <li><a href="/docs" class="hover:text-cyan">SDK</a></li>
        </ul>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-semibold text-navy">Company</h3>
        <ul class="space-y-2 text-sm text-kelta-700">
          <li><a href="#" class="hover:text-cyan">About</a></li>
          <li><a href="#" class="hover:text-cyan">Blog</a></li>
          <li><a href="#" class="hover:text-cyan">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-10 border-t border-gray-200 pt-6 text-center text-sm text-gray-400">
      &copy; {currentYear} Kelta. All rights reserved.
    </div>
  </div>
</footer>
