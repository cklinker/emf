---
const navLinks = [
  { label: 'Features', href: '/features' },
  { label: 'Docs', href: '/docs' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'GitHub', href: 'https://github.com/cklinker/emf', external: true },
];
---

<header class="sticky top-0 z-50 border-b border-gray-100 bg-white/80 backdrop-blur-lg">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2 text-xl font-bold text-kelta-700">
      <!-- Logo placeholder — will be replaced with SVG from KEL-28 -->
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-kelta-600 text-sm font-bold text-white">K</span>
      Kelta
    </a>
    <div class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-gray-600 transition-colors hover:text-kelta-600"
          {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/cklinker/emf"
        class="rounded-lg bg-kelta-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-kelta-700"
      >
        Get Started
      </a>
    </div>
    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="flex h-10 w-10 items-center justify-center rounded-lg text-gray-600 hover:bg-gray-100 md:hidden"
      aria-label="Toggle menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-gray-100 bg-white px-6 py-4 md:hidden">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="block py-2 text-sm font-medium text-gray-600 hover:text-kelta-600"
        {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        {link.label}
      </a>
    ))}
    <a
      href="https://github.com/cklinker/emf"
      class="mt-2 block rounded-lg bg-kelta-600 px-4 py-2 text-center text-sm font-medium text-white hover:bg-kelta-700"
    >
      Get Started
    </a>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
