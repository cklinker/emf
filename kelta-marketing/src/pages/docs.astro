---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  {
    title: 'Getting Started',
    links: [
      { label: 'Quick Start Guide', href: 'https://github.com/cklinker/emf#readme' },
      { label: 'Docker Compose Setup', href: 'https://github.com/cklinker/emf/blob/main/docker-compose.yml' },
      { label: 'Architecture Overview', href: '/features' },
    ],
  },
  {
    title: 'Developer SDK',
    links: [
      { label: 'TypeScript SDK (@kelta/sdk)', href: 'https://github.com/cklinker/emf/tree/main/kelta-web/packages/sdk' },
      { label: 'React Components (@kelta/components)', href: 'https://github.com/cklinker/emf/tree/main/kelta-web/packages/components' },
      { label: 'Plugin SDK (@kelta/plugin-sdk)', href: 'https://github.com/cklinker/emf/tree/main/kelta-web/packages/plugin-sdk' },
      { label: 'CLI (@kelta/cli)', href: 'https://github.com/cklinker/emf/tree/main/kelta-web/packages/cli' },
    ],
  },
  {
    title: 'API Reference',
    links: [
      { label: 'JSON:API Endpoints', href: 'https://github.com/cklinker/emf/blob/main/FEATURES.md' },
      { label: 'Authentication & OAuth 2.0', href: 'https://github.com/cklinker/emf/blob/main/FEATURES.md' },
      { label: 'Webhook Integration', href: 'https://github.com/cklinker/emf/blob/main/FEATURES.md' },
    ],
  },
  {
    title: 'Deployment',
    links: [
      { label: 'Kubernetes Deployment', href: 'https://github.com/cklinker/emf/tree/main/docker' },
      { label: 'ArgoCD GitOps', href: 'https://github.com/cklinker/emf' },
      { label: 'Environment Configuration', href: 'https://github.com/cklinker/emf' },
    ],
  },
];
---

<BaseLayout title="Documentation" description="Guides, API reference, and SDK documentation for Kelta.">
  <section class="bg-gradient-to-b from-kelta-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-6 text-center">
      <h1 class="text-4xl font-extrabold text-navy md:text-5xl">Documentation</h1>
      <p class="mt-4 text-lg text-kelta-700">
        Guides, API reference, and SDK documentation to get you building fast.
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-8 md:grid-cols-2">
        {sections.map((section) => (
          <div class="rounded-xl border border-gray-100 p-8">
            <h2 class="mb-4 text-xl font-bold text-navy">{section.title}</h2>
            <ul class="space-y-3">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="flex items-center gap-2 text-sm text-cyan hover:text-blue"
                    target={link.href.startsWith('http') ? '_blank' : undefined}
                    rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                  >
                    <span>&#8594;</span>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="mt-12 rounded-xl border border-kelta-100 bg-kelta-50 p-8 text-center">
        <p class="text-sm text-navy">
          Full documentation site coming soon. In the meantime, check out the
          <a href="https://github.com/cklinker/emf" class="font-semibold underline" target="_blank" rel="noopener noreferrer">
            GitHub repository
          </a>
          for the latest guides and examples.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
