---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureCard from '../components/FeatureCard.astro';

const features = [
  {
    title: 'Dynamic Schema Engine',
    description: 'Define and modify your data model at runtime. 27 field types, relationships, computed fields, validation rules, and schema versioning — all without touching code or restarting services.',
    icon: '🗃️',
  },
  {
    title: 'Auto-Generated REST API',
    description: 'Every collection gets a full JSON:API-compliant REST API instantly. Filtering, sorting, pagination, sparse fieldsets, relationship includes, and atomic bulk operations out of the box.',
    icon: '⚡',
  },
  {
    title: 'Visual Workflow Builder',
    description: 'Design automation with a drag-and-drop flow canvas inspired by AWS Step Functions. 8 state types, 16 built-in action handlers, durable execution, and triggers for record events, webhooks, or cron schedules.',
    icon: '🔄',
  },
  {
    title: 'Enterprise-Grade Security',
    description: 'Role-based access control with profiles, permission sets, and groups. Field-level AES-256-GCM encryption. Row Level Security per tenant. Cerbos policy engine integration for attribute-based rules. MFA with TOTP and SMS.',
    icon: '🔒',
  },
  {
    title: 'Multi-Tenant by Default',
    description: 'URL-based tenant resolution with custom domain routing. Per-tenant schemas, governor limits, and resource isolation. Scale horizontally without rearchitecting.',
    icon: '🏢',
  },
  {
    title: 'Full Observability Stack',
    description: 'Distributed tracing via OpenTelemetry and Jaeger. Structured logging to OpenSearch. Request metrics with P50/P75/P95/P99 latency breakdowns. Audit trails for every change.',
    icon: '📊',
  },
];

const stats = [
  { value: '27', label: 'Field types' },
  { value: '70+', label: 'Admin pages' },
  { value: '16', label: 'Workflow handlers' },
  { value: '111', label: 'DB migrations' },
];

const howItWorks = [
  { step: '1', title: 'Define your schema', description: 'Create collections and fields through the admin UI or API. Relationships, validations, and computed fields configure in seconds.' },
  { step: '2', title: 'Get APIs instantly', description: 'Every collection exposes a full REST API with filtering, sorting, pagination, and bulk operations. No code generation step.' },
  { step: '3', title: 'Add automation', description: 'Build workflows visually with the flow canvas. Trigger on record changes, schedules, or webhooks. Chain data operations, HTTP callouts, emails, and custom logic.' },
  { step: '4', title: 'Ship with confidence', description: 'Multi-tenant isolation, RBAC, encryption, rate limiting, and observability are built in from day one. Not bolted on later.' },
];
---

<BaseLayout title="Build microservices. Not boilerplate." description="Kelta is a metadata-driven platform for building enterprise applications at runtime. Define collections, fields, workflows, and APIs — without redeploying.">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-b from-kelta-50 to-white">
    <div class="mx-auto max-w-7xl px-6 py-24 text-center md:py-32">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-4xl font-extrabold tracking-tight text-navy md:text-6xl">
          Build microservices.
          <span class="bg-gradient-to-r from-cyan to-blue bg-clip-text text-transparent">Not boilerplate.</span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-kelta-700 md:text-xl">
          Kelta is a metadata-driven platform for building enterprise applications at runtime. Define collections, fields, workflows, and APIs — without redeploying.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="https://github.com/cklinker/emf"
            class="rounded-lg bg-navy px-8 py-3 text-base font-semibold text-white shadow-lg transition-all hover:bg-kelta-800 hover:shadow-xl"
          >
            Get Started on GitHub
          </a>
          <a
            href="/docs"
            class="rounded-lg border border-gray-200 bg-white px-8 py-3 text-base font-semibold text-kelta-700 transition-colors hover:border-cyan hover:text-cyan"
          >
            Read the Docs
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-y border-gray-100 bg-white">
    <div class="mx-auto max-w-7xl px-6 py-12">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl font-bold text-cyan">{stat.value}</div>
            <div class="mt-1 text-sm text-kelta-700">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="bg-kelta-50 py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-16 text-center">
        <h2 class="text-3xl font-bold text-navy md:text-4xl">Everything you need to build, automate, and scale</h2>
        <p class="mt-4 text-lg text-kelta-700">
          A complete platform with the power of Salesforce, without the complexity, cost, or lock-in.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {features.map((feature) => (
          <FeatureCard title={feature.title} description={feature.description} icon={feature.icon} />
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-16 text-center">
        <h2 class="text-3xl font-bold text-navy md:text-4xl">How It Works</h2>
      </div>
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {howItWorks.map((item) => (
          <div class="relative">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-cyan to-blue text-sm font-bold text-white">
              {item.step}
            </div>
            <h3 class="mb-2 text-lg font-semibold text-navy">{item.title}</h3>
            <p class="text-sm leading-relaxed text-kelta-700">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Kelta -->
  <section class="bg-kelta-50 py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-16 text-center">
        <h2 class="text-3xl font-bold text-navy md:text-4xl">Why Kelta?</h2>
      </div>
      <div class="grid gap-8 md:grid-cols-2">
        <div class="rounded-xl border border-gray-100 bg-white p-8">
          <h3 class="mb-3 text-lg font-semibold text-navy">Stop rebuilding the same platform layer</h3>
          <p class="text-sm leading-relaxed text-kelta-700">
            Every microservices team writes the same infrastructure: auth, RBAC, CRUD APIs, event buses, tenant isolation, rate limiting. Kelta ships all of it as a configurable runtime so your team can focus on what makes your product different.
          </p>
        </div>
        <div class="rounded-xl border border-gray-100 bg-white p-8">
          <h3 class="mb-3 text-lg font-semibold text-navy">Runtime configuration, not deployment cycles</h3>
          <p class="text-sm leading-relaxed text-kelta-700">
            Traditional platforms require code changes and redeployments for schema updates. Kelta's metadata-driven architecture lets you add collections, fields, validation rules, and workflows while the system is running.
          </p>
        </div>
        <div class="rounded-xl border border-gray-100 bg-white p-8">
          <h3 class="mb-3 text-lg font-semibold text-navy">Standards-based, not proprietary</h3>
          <p class="text-sm leading-relaxed text-kelta-700">
            JSON:API for REST. OIDC for auth. OpenTelemetry for observability. Kafka for events. PostgreSQL for persistence. Kelta builds on the tools your team already knows — no vendor lock-in, no custom query languages.
          </p>
        </div>
        <div class="rounded-xl border border-gray-100 bg-white p-8">
          <h3 class="mb-3 text-lg font-semibold text-navy">Open source. Full stack.</h3>
          <p class="text-sm leading-relaxed text-kelta-700">
            Gateway, worker, SDK, admin UI — the entire platform is open source. Run it on your infrastructure, extend it with modules, and own your data.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="py-24">
    <div class="mx-auto max-w-5xl px-6">
      <h2 class="mb-10 text-center text-3xl font-bold text-navy">Tech Stack</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="py-3 pr-6 font-semibold text-navy">Layer</th>
              <th class="py-3 font-semibold text-navy">Technology</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100"><td class="py-3 pr-6 font-medium text-navy">Backend</td><td class="py-3 font-mono text-xs text-kelta-700">Java 21, Spring Boot 3.2</td></tr>
            <tr class="border-b border-gray-100"><td class="py-3 pr-6 font-medium text-navy">Frontend</td><td class="py-3 font-mono text-xs text-kelta-700">TypeScript, React, Vite, Tailwind CSS</td></tr>
            <tr class="border-b border-gray-100"><td class="py-3 pr-6 font-medium text-navy">Data</td><td class="py-3 font-mono text-xs text-kelta-700">PostgreSQL 15, Redis 7</td></tr>
            <tr class="border-b border-gray-100"><td class="py-3 pr-6 font-medium text-navy">Events</td><td class="py-3 font-mono text-xs text-kelta-700">Kafka 3.7 (KRaft)</td></tr>
            <tr class="border-b border-gray-100"><td class="py-3 pr-6 font-medium text-navy">Auth</td><td class="py-3 font-mono text-xs text-kelta-700">Keycloak (OIDC)</td></tr>
            <tr class="border-b border-gray-100"><td class="py-3 pr-6 font-medium text-navy">Observability</td><td class="py-3 font-mono text-xs text-kelta-700">OpenTelemetry, Jaeger, OpenSearch</td></tr>
            <tr class="border-b border-gray-100"><td class="py-3 pr-6 font-medium text-navy">Deployment</td><td class="py-3 font-mono text-xs text-kelta-700">Docker, Kubernetes, ArgoCD</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy py-20">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl font-bold text-white md:text-4xl">Ready to stop rebuilding infrastructure?</h2>
      <p class="mt-4 text-lg text-gray-300">
        Kelta is open source and ready to run. Clone the repo, spin up the stack, and have a working platform in minutes.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="https://github.com/cklinker/emf"
          class="rounded-lg bg-gradient-to-r from-cyan to-blue px-8 py-3 text-base font-semibold text-white transition-all hover:shadow-lg"
        >
          View on GitHub
        </a>
        <a
          href="/docs"
          class="rounded-lg border border-gray-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:border-cyan hover:text-cyan"
        >
          Read the Docs
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
