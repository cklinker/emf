---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pricing" description="Kelta is open source and free to self-host.">
  <section class="bg-gradient-to-b from-kelta-50 to-white py-20">
    <div class="mx-auto max-w-7xl px-6 text-center">
      <h1 class="text-4xl font-extrabold text-gray-900 md:text-5xl">Simple, transparent pricing</h1>
      <p class="mt-4 text-lg text-gray-600">
        Open source, self-hosted, free forever. No per-seat licensing.
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-4xl px-6">
      <div class="grid gap-8 md:grid-cols-2">
        <!-- Open Source -->
        <div class="rounded-xl border-2 border-kelta-200 bg-white p-8">
          <div class="mb-6">
            <h2 class="text-2xl font-bold text-gray-900">Open Source</h2>
            <div class="mt-4">
              <span class="text-4xl font-extrabold text-gray-900">$0</span>
              <span class="text-gray-500"> / forever</span>
            </div>
          </div>
          <ul class="mb-8 space-y-3 text-sm text-gray-600">
            <li class="flex items-start gap-2">
              <span class="text-kelta-500">&#10003;</span>
              Full platform — all features included
            </li>
            <li class="flex items-start gap-2">
              <span class="text-kelta-500">&#10003;</span>
              Unlimited users, collections, and records
            </li>
            <li class="flex items-start gap-2">
              <span class="text-kelta-500">&#10003;</span>
              Self-hosted on your infrastructure
            </li>
            <li class="flex items-start gap-2">
              <span class="text-kelta-500">&#10003;</span>
              Community support via GitHub
            </li>
            <li class="flex items-start gap-2">
              <span class="text-kelta-500">&#10003;</span>
              Apache 2.0 license
            </li>
          </ul>
          <a
            href="https://github.com/cklinker/emf"
            class="block rounded-lg bg-kelta-600 py-3 text-center text-sm font-semibold text-white hover:bg-kelta-700"
          >
            Get Started on GitHub
          </a>
        </div>

        <!-- Enterprise -->
        <div class="rounded-xl border border-gray-200 bg-white p-8">
          <div class="mb-6">
            <h2 class="text-2xl font-bold text-gray-900">Enterprise</h2>
            <div class="mt-4">
              <span class="text-4xl font-extrabold text-gray-900">Custom</span>
            </div>
          </div>
          <ul class="mb-8 space-y-3 text-sm text-gray-600">
            <li class="flex items-start gap-2">
              <span class="text-kelta-500">&#10003;</span>
              Everything in Open Source
            </li>
            <li class="flex items-start gap-2">
              <span class="text-kelta-500">&#10003;</span>
              Priority support and SLAs
            </li>
            <li class="flex items-start gap-2">
              <span class="text-kelta-500">&#10003;</span>
              Deployment assistance
            </li>
            <li class="flex items-start gap-2">
              <span class="text-kelta-500">&#10003;</span>
              Custom feature development
            </li>
            <li class="flex items-start gap-2">
              <span class="text-kelta-500">&#10003;</span>
              Training and onboarding
            </li>
          </ul>
          <a
            href="#"
            class="block rounded-lg border border-gray-200 py-3 text-center text-sm font-semibold text-gray-700 hover:border-kelta-300 hover:text-kelta-600"
          >
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
