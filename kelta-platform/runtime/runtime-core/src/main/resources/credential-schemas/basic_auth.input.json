{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Basic Auth",
  "type": "object",
  "required": ["username", "password"],
  "properties": {
    "username": {
      "type": "string",
      "title": "Username",
      "minLength": 1,
      "maxLength": 200
    },
    "password": {
      "type": "string",
      "format": "secret",
      "title": "Password",
      "minLength": 1
    }
  }
}
