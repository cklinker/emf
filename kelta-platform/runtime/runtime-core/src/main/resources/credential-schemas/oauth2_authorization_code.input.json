{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OAuth 2.0 — Authorization Code",
  "type": "object",
  "required": ["clientId", "clientSecret", "authorizationUrl", "tokenUrl"],
  "properties": {
    "clientId": {
      "type": "string",
      "title": "Client ID",
      "minLength": 1,
      "maxLength": 500
    },
    "clientSecret": {
      "type": "string",
      "format": "secret",
      "title": "Client secret",
      "minLength": 1
    },
    "authorizationUrl": {
      "type": "string",
      "format": "uri",
      "title": "Authorization URL"
    },
    "tokenUrl": {
      "type": "string",
      "format": "uri",
      "title": "Token URL"
    },
    "scopes": {
      "type": "array",
      "items": { "type": "string" },
      "title": "Scopes"
    },
    "redirectUri": {
      "type": "string",
      "format": "uri",
      "title": "Redirect URI",
      "description": "Must match the redirect URI registered with the IdP. Set automatically by the platform when blank."
    }
  }
}
