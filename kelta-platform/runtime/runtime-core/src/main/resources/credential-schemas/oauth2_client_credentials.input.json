{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OAuth 2.0 — Client Credentials",
  "type": "object",
  "required": ["clientId", "clientSecret", "tokenUrl"],
  "properties": {
    "clientId": {
      "type": "string",
      "title": "Client ID",
      "minLength": 1,
      "maxLength": 500
    },
    "clientSecret": {
      "type": "string",
      "format": "secret",
      "title": "Client secret",
      "minLength": 1
    },
    "tokenUrl": {
      "type": "string",
      "format": "uri",
      "title": "Token URL",
      "description": "OAuth 2.0 token endpoint (e.g., https://login.example.com/oauth2/token)."
    },
    "scopes": {
      "type": "array",
      "items": { "type": "string" },
      "title": "Scopes",
      "description": "Space-separated scopes to request (e.g., read:users write:orders)."
    },
    "audience": {
      "type": "string",
      "title": "Audience (optional)",
      "description": "OAuth audience parameter, if required by the IdP."
    }
  }
}
