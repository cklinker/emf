    { "name": "not_fn", "expression": "NOT(true)", "context": {}, "expected": false },

    { "name": "len_string", "expression": "LEN('hello')", "context": {}, "expected": 5 },
    { "name": "len_field", "expression": "LEN(name)", "context": { "name": "Alice" }, "expected": 5 },
    { "name": "len_null_zero", "expression": "LEN(name)", "context": { "name": null }, "expected": 0 },

    { "name": "contains_yes", "expression": "CONTAINS('hello world', 'world')", "context": {}, "expected": true },
    { "name": "contains_no", "expression": "CONTAINS('hello', 'xyz')", "context": {}, "expected": false },

    { "name": "upper", "expression": "UPPER('abc')", "context": {}, "expected": "ABC" },
    { "name": "lower", "expression": "LOWER('XYZ')", "context": {}, "expected": "xyz" },
    { "name": "trim", "expression": "TRIM('  hi  ')", "context": {}, "expected": "hi" },
    { "name": "upper_null", "expression": "UPPER(name)", "context": { "name": null }, "expected": null },

    { "name": "text_number", "expression": "TEXT(42)", "context": {}, "expected": "42" },
    { "name": "text_null_empty", "expression": "TEXT(name)", "context": { "name": null }, "expected": "" },

    { "name": "value_string", "expression": "VALUE('3.14')", "context": {}, "expected": 3.14, "expectedType": "number" },
    { "name": "value_null_zero", "expression": "VALUE(missing)", "context": {}, "expected": 0 },

    { "name": "round_two_places", "expression": "ROUND(3.14159, 2)", "context": {}, "expected": 3.14 },
    { "name": "round_zero_places", "expression": "ROUND(3.7, 0)", "context": {}, "expected": 4 },
    { "name": "abs_negative", "expression": "ABS(-5)", "context": {}, "expected": 5 },
    { "name": "max_fn", "expression": "MAX(3, 7)", "context": {}, "expected": 7 },
    { "name": "min_fn", "expression": "MIN(3, 7)", "context": {}, "expected": 3 },

    { "name": "regex_match", "expression": "REGEX('abc123', '[a-z]+[0-9]+')", "context": {}, "expected": true },
    { "name": "regex_no_match", "expression": "REGEX('abc', '[0-9]+')", "context": {}, "expected": false },

    { "name": "datediff_days", "expression": "DATEDIFF('2026-01-10', '2026-01-01')", "context": {}, "expected": 9 },
    { "name": "datediff_negative", "expression": "DATEDIFF('2026-01-01', '2026-01-10')", "context": {}, "expected": -9 },

    { "name": "discount_validation_invalid", "expression": "discount > unit_price * 0.5", "context": { "discount": 20, "unit_price": 30 }, "expected": true },
    { "name": "discount_validation_valid", "expression": "discount > unit_price * 0.5", "context": { "discount": 5, "unit_price": 30 }, "expected": false },

    { "name": "nested_function_calls", "expression": "TRIM(UPPER(sku))", "context": { "sku": "  abc-123  " }, "expected": "ABC-123" },
    { "name": "if_with_blankvalue", "expression": "IF(ISBLANK(name), 'anonymous', name)", "context": { "name": null }, "expected": "anonymous" },

    { "name": "unterminated_string_throws", "expression": "'broken", "context": {}, "throws": true },
    { "name": "unknown_function_throws", "expression": "BOGUS(1)", "context": {}, "throws": true },
    { "name": "trailing_garbage_throws", "expression": "1 + 2 garbage", "context": {}, "throws": true },
    { "name": "unbalanced_paren_throws", "expression": "(1 + 2", "context": {}, "throws": true }
