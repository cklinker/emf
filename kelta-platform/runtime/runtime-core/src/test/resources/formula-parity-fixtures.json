    { "name": "lte_eq", "expression": "5 <= 5", "context": {}, "expected": true },
    { "name": "gte_eq", "expression": "5 >= 5", "context": {}, "expected": true },
    { "name": "compare_strings_lex", "expression": "'apple' < 'banana'", "context": {}, "expected": true },
    { "name": "compare_null_returns_zero_eq", "expression": "amount > 0", "context": { "amount": null }, "expected": false },

    { "name": "and_true", "expression": "true && true", "context": {}, "expected": true },
    { "name": "and_false", "expression": "true && false", "context": {}, "expected": false },
    { "name": "or_true", "expression": "false || true", "context": {}, "expected": true },
    { "name": "not", "expression": "!false", "context": {}, "expected": true },
    { "name": "complex_logic", "expression": "(a > 0) && (b < 10 || c == 'x')", "context": { "a": 5, "b": 20, "c": "x" }, "expected": true },

    { "name": "if_true_branch", "expression": "IF(score > 50, 'pass', 'fail')", "context": { "score": 75 }, "expected": "pass" },
