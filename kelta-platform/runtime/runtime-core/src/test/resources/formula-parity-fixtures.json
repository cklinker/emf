    { "name": "literal_decimal", "expression": "3.14", "context": {}, "expected": 3.14, "expectedType": "number" },
    { "name": "literal_string_single", "expression": "'hello'", "context": {}, "expected": "hello" },
    { "name": "literal_string_double", "expression": "\"world\"", "context": {}, "expected": "world" },
    { "name": "literal_true", "expression": "true", "context": {}, "expected": true },
    { "name": "literal_false", "expression": "FALSE", "context": {}, "expected": false },
    { "name": "literal_null", "expression": "null", "context": {}, "expected": null },

    { "name": "field_ref_number", "expression": "amount", "context": { "amount": 100 }, "expected": 100 },
    { "name": "field_ref_string", "expression": "name", "context": { "name": "Alice" }, "expected": "Alice" },
    { "name": "field_ref_missing", "expression": "missing", "context": {}, "expected": null },

    { "name": "add_numbers", "expression": "2 + 3", "context": {}, "expected": 5 },
    { "name": "subtract", "expression": "10 - 4", "context": {}, "expected": 6 },
