{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/main.tsx",
    "index.html"
  ],
  "project": [
    "src/**/*.{ts,tsx}"
  ],
  "ignore": [
    "src/test/**",
    "src/**/*.test.{ts,tsx}",
    "src/**/*.spec.{ts,tsx}"
  ],
  "ignoreDependencies": [
    "@types/node"
  ],
  "vite": {
    "config": ["vite.config.ts"]
  },
  "vitest": {
    "config": ["vitest.config.ts", "vite.config.ts"]
  }
}
