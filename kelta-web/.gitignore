# Package manager
# package-lock.json is intentionally committed so CI builds are
# reproducible and survive broken upstream releases (e.g. Vue 3.5.36
# was published with @vue/compiler-dom pinned to a missing
# @vue/shared@3.5.36, breaking every fresh npm install).
