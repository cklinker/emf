{
  "name": "@kelta/components",
  "version": "0.0.1",
  "description": "Reusable React component library for Kelta",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./video": {
      "import": "./dist/video.js",
      "require": "./dist/video.cjs",
      "types": "./dist/video.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@kelta/formula": "^0.0.1",
    "@kelta/sdk": "^0.0.1",
    "@livekit/components-react": "^2.9.0",
    "@livekit/components-styles": "^1.1.0",
    "@tanstack/react-query": "^5.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "livekit-client": "^2.20.0",
    "lucide-react": "^0.500.0",
    "maplibre-gl": "^4.0.0 || ^5.0.0",
    "radix-ui": "^1.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "react-router-dom": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "maplibre-gl": {
      "optional": true
    },
    "@livekit/components-react": {
      "optional": true
    },
    "@livekit/components-styles": {
      "optional": true
    },
    "livekit-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@livekit/components-react": "^2.9.23",
    "@livekit/components-styles": "^1.2.0",
    "@tanstack/react-query": "^5.24.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "livekit-client": "^2.20.1",
    "lucide-react": "^0.563.0",
    "maplibre-gl": "^5.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.51.0",
    "react-router-dom": "^7.0.0"
  },
  "keywords": [
    "kelta",
    "react",
    "components",
    "ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kelta/kelta-web.git",
    "directory": "packages/components"
  }
}
