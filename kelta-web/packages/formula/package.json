{
  "name": "@kelta/formula",
  "version": "0.0.1",
  "description": "Kelta formula expression evaluator (TypeScript port of the server-side engine)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "kelta",
    "formula",
    "expression",
    "evaluator"
  ],
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  }
}
